<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="root-pane" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="org.analizador.MainController">

    <!-- BARRA SUPERIOR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="top-bar">
            <Label styleClass="app-title" text="Analizador Lexico Mini-Pascal" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnTheme" onAction="#toggleTheme" styleClass="btn-secondary" text="☀ Tema" />
            <Button fx:id="btnOpen" onAction="#openFile" styleClass="btn-secondary" text="📂 Abrir" />
            <Button fx:id="btnAnalyze" onAction="#analyze" styleClass="btn-primary" text="▶ Analisar" />
            <Button fx:id="btnClear" onAction="#clear" styleClass="btn-secondary" text="✕ Limpar" />
        </HBox>
    </top>

    <!-- ÁREA CENTRAL -->
    <center>
        <SplitPane dividerPositions="0.45" styleClass="main-split">

            <!-- EDITOR (esquerda) -->
            <VBox styleClass="panel">
                <Label styleClass="panel-title" text="Código Fonte" />
                <HBox VBox.vgrow="ALWAYS">
                    <!-- numeração de linhas -->
                    <TextArea fx:id="lineNumbers" editable="false" prefWidth="45" styleClass="line-numbers" text="1" />
                    <!-- editor -->
                    <TextArea fx:id="codeEditor" promptText="Escreve ou abre um ficheiro .pas aqui..." styleClass="code-editor" wrapText="false" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>

            <!-- PAINEL DIREITO -->
            <SplitPane dividerPositions="0.6" orientation="VERTICAL">

                <!-- TABELA DE TOKENS (cima) -->
                <VBox styleClass="panel">
                    <Label styleClass="panel-title" text="Tokens" />
                    <TableView fx:id="tokenTable" prefHeight="600.0" prefWidth="525.0" styleClass="token-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colValor" prefWidth="235.0" text="Valor" />
                            <TableColumn fx:id="colTipo" prefWidth="210.0" text="Tipo" />
                            <TableColumn fx:id="colLinha" prefWidth="70" text="Linha" />
                            <TableColumn fx:id="colColuna" prefWidth="70" text="Coluna" />
                        </columns>
                        <placeholder>
                            <Label styleClass="placeholder-label" text="Nenhum token ainda." />
                        </placeholder>
                    </TableView>
                </VBox>

                <!-- ERROS (baixo) -->
                <VBox styleClass="panel">
                    <Label styleClass="panel-title" text="Erros" />
                    <ListView fx:id="errorList" styleClass="error-list" VBox.vgrow="ALWAYS">
                        <placeholder>
                            <Label styleClass="placeholder-label" text="Nenhum erro detectado." />
                        </placeholder>
                    </ListView>
                </VBox>

            </SplitPane>
        </SplitPane>
    </center>

    <!-- BARRA INFERIOR -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="status-bar">
            <Label fx:id="lblTotal" styleClass="status-label" text="Tokens: 0" />
            <Label fx:id="lblSpecial" styleClass="status-label" text="Palavras-chave: 0" />
            <Label fx:id="lblIdents" styleClass="status-label" text="Identificadores: 0" />
            <Label fx:id="lblErros" styleClass="status-label" text="Erros: 0" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblFicheiro" styleClass="status-label-muted" text="Sem ficheiro aberto" />
        </HBox>
    </bottom>

</BorderPane>
